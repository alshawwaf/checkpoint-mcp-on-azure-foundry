# Local runtime env for chkpmcpaz -- copy to .env (gitignored) and fill in.
# Auto-loaded by every command (chat/deploy); explicit `export`s still win.
#
# Check Point AI Guardrail (Lakera Guard) -- the Check Point-native guardrail.
# Selecting it here (or via --guardrail-provider lakera) makes `chat --guardrail`
# screen the prompt inline before any model/tool call.
CHKP_GUARDRAIL_PROVIDER=lakera
LAKERA_API_KEY=
LAKERA_PROJECT_ID=
# Optional endpoint override (defaults to the Guard v2 API):
# LAKERA_API_URL=https://api.lakera.ai/v2/guard
#
# The older LAKERA_GUARD_API_KEY / LAKERA_GUARD_PROJECT_ID / LAKERA_GUARD_URL
# names are also accepted as aliases.
